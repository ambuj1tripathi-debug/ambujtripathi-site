---
// Photos: ambuj-window.jpg = hero; utrecht-1.jpg … utrecht-10.jpg = gallery
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ambuj Tripathi</title>
  <meta name="description" content="Finance professional writing at the intersection of credit risk, development finance, and global markets. Based in Utrecht."/>
  <meta property="og:title" content="Ambuj Tripathi"/>
  <meta property="og:url" content="https://ambujtripathi.nl"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Instrument+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    /* ── Glim palette ── */
    :root {
      --paper:  #ece6d6;
      --paper2: #f5f0e1;
      --paperD: #dfd7c2;
      --ink:    #2a3540;
      --ink2:   #48576a;
      --mist:   #8896a4;
      --fog:    #c6d0d9;
      --sky:    #b9c8d4;
      --sky2:   #d2dce4;
      --seaD:   #6f879a;
      --sea:    #92a7b7;
      --linen:  #d6c2b0;
      --night:  #2c3845;
      --nightD: #202934;
      --rule:   rgba(42,53,64,0.16);
      --ruleS:  rgba(42,53,64,0.10);
      --edge:   rgba(255,255,255,0.10);
      --edge2:  rgba(255,255,255,0.18);
      --fog-grad: linear-gradient(90deg, #b9c8d4 0%, #c8c0c6 35%, #d4c0a8 70%, #c6b09c 100%);
    }
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; font-size:16px; }
    body {
      font-family:'Instrument Sans', -apple-system, system-ui, sans-serif;
      background: var(--paper);
      color: var(--ink);
      font-weight:300;
      line-height:1.7;
      overflow-x:hidden;
    }
    .serif { font-family:'Cormorant Garamond','Times New Roman',serif; }

    /* fog gradient text */
    .fog-text {
      background: var(--fog-grad);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent; color: transparent;
      font-style: italic;
    }
    /* fog hairline */
    .fog-line {
      width:100%; height:1px;
      background: var(--fog-grad);
    }

    /* ── Nav ── */
    nav {
      position:sticky; top:0; z-index:10;
      padding:20px 64px;
      background:rgba(236,230,214,0.92);
      backdrop-filter:blur(10px);
      border-bottom: 0.5px solid var(--ruleS);
      display:grid; grid-template-columns:1fr auto 1fr; align-items:center;
    }
    .nav-logo {
      font-family:'Cormorant Garamond',serif;
      font-size:18px; letter-spacing:0.06em; color:var(--ink);
    }
    .nav-logo em { color:var(--seaD); font-style:italic; }
    .nav-links {
      display:flex; gap:32px; list-style:none; justify-content:center;
      font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--ink2);
    }
    .nav-links a { text-decoration:none; color:inherit; cursor:pointer; transition:color .2s; }
    .nav-links a:hover { color:var(--seaD); }
    .nav-status {
      justify-self:end; display:flex; align-items:center; gap:10px;
      font-size:10px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--mist);
    }
    .nav-dot {
      width:6px; height:6px; border-radius:50%;
      background:var(--sea); box-shadow:0 0 8px rgba(146,167,183,0.6);
    }

    /* ── Hero ── */
    .hero {
      display:grid; grid-template-columns:1fr 1fr;
      min-height:720px;
      border-bottom: 0.5px solid var(--ruleS);
    }
    .hero-left {
      padding:80px 56px 56px 64px;
      display:flex; flex-direction:column; justify-content:space-between;
      border-right: 0.5px solid var(--ruleS);
      position:relative;
    }
    .hero-eyebrow {
      display:flex; align-items:center; gap:14px;
      font-size:10px; letter-spacing:0.32em; text-transform:uppercase;
      color:var(--mist); margin-bottom:28px;
    }
    .hero-eyebrow-line {
      display:inline-block; width:24px; height:1px;
      background: var(--fog-grad);
    }
    .hero-name {
      font-family:'Cormorant Garamond',serif;
      font-size:clamp(64px, 8vw, 98px);
      font-weight:300; line-height:0.95;
      letter-spacing:-0.018em; color:var(--ink);
    }
    .hero-role {
      font-family:'Cormorant Garamond',serif;
      font-style:italic; font-size:21px;
      color:var(--ink2); line-height:1.5; max-width:420px;
      margin-top:28px;
    }
    .hero-bio {
      font-size:14px; color:var(--ink2);
      max-width:440px; line-height:1.9; font-weight:300;
      margin-top:30px;
    }
    .hero-bio strong { font-weight:500; color:var(--ink); }
    .hero-bottom { display:flex; flex-direction:column; gap:24px; }
    .hero-actions { display:flex; gap:14px; align-items:center; }
    .btn-primary {
      background:var(--ink); color:var(--paper);
      padding:13px 28px; border:none;
      font-size:11px; letter-spacing:0.18em; text-transform:uppercase;
      cursor:pointer; font-family:'Instrument Sans',sans-serif; font-weight:400;
      transition:background .2s; text-decoration:none; display:inline-block;
    }
    .btn-primary:hover { background:var(--seaD); }
    .btn-ghost {
      font-size:11px; letter-spacing:0.16em; text-transform:uppercase;
      color:var(--ink2); border:none;
      border-bottom:0.5px solid var(--fog); padding-bottom:2px;
      background:none; cursor:pointer;
      font-family:'Instrument Sans',sans-serif; font-weight:300;
      transition:color .2s, border-color .2s;
    }
    .btn-ghost:hover { color:var(--seaD); border-color:var(--seaD); }
    .hero-socials {
      display:flex; gap:22px;
      font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
      color:var(--mist);
    }
    .hero-socials a { color:inherit; text-decoration:none; transition:color .2s; }
    .hero-socials a:hover { color:var(--seaD); }
    .hero-accent-line {
      position:absolute; left:64px; top:268px; width:56px;
    }
    .hero-right {
      position:relative; overflow:hidden;
      background:var(--sky2);
    }
    .hero-right img {
      position:absolute; inset:0; width:100%; height:100%;
      object-fit:cover; object-position:60% 50%;
    }
    .hero-right-overlay {
      position:absolute; inset:0;
      background:linear-gradient(180deg, rgba(185,200,212,0.06) 0%, rgba(42,53,64,0.18) 100%);
      pointer-events:none;
    }
    .hero-caption {
      position:absolute; left:24px; top:24px;
      padding:10px 14px;
      background:rgba(236,230,214,0.86); backdrop-filter:blur(6px);
      border:0.5px solid rgba(42,53,64,0.12);
    }
    .hero-caption-tag {
      font-size:9.5px; letter-spacing:0.28em; text-transform:uppercase;
      color:var(--mist); margin-bottom:4px;
    }
    .hero-caption-text {
      font-family:'Cormorant Garamond',serif;
      font-style:italic; font-size:14px; color:var(--ink);
    }
    .hero-self {
      position:absolute; right:18px; bottom:18px;
      font-family:'Cormorant Garamond',serif;
      font-style:italic; font-size:13px;
      color:rgba(236,230,214,0.85);
      text-shadow:0 1px 6px rgba(0,0,0,0.3);
    }

    /* ── Author strip ── */
    .author-strip {
      display:flex; align-items:center; gap:24px;
      padding:32px 64px;
      border-bottom:0.5px solid var(--ruleS);
      background:var(--paper);
    }
    .author-portrait {
      width:72px; height:72px;
      border-radius:50%;
      object-fit:cover; object-position:center top;
      border:1.5px solid var(--paperD);
      flex-shrink:0;
    }
    .author-portrait-fallback {
      width:72px; height:72px; border-radius:50%; flex-shrink:0;
      background:linear-gradient(135deg,var(--sky),var(--linen));
    }
    .author-strip-name {
      font-family:'Cormorant Garamond',serif;
      font-size:18px; font-weight:500; color:var(--ink); line-height:1;
    }
    .author-strip-line {
      font-size:13px; color:var(--ink2); margin-top:5px; letter-spacing:0.01em;
    }

    /* ── Now strip ── */
    .now-strip {
      padding:40px 64px;
      border-bottom:0.5px solid var(--ruleS);
      display:grid; grid-template-columns:auto 1fr; gap:48px;
      background:var(--paper2);
    }
    .now-label {
      font-size:10px; letter-spacing:0.32em; text-transform:uppercase;
      color:var(--mist); padding-top:4px;
    }
    .now-date {
      font-family:'Cormorant Garamond',serif;
      font-style:italic; font-size:16px; color:var(--ink2); margin-top:6px;
    }
    .now-grid {
      display:grid; grid-template-columns:repeat(3,1fr); gap:24px 56px;
    }
    .now-item-label {
      font-size:9.5px; letter-spacing:0.24em; text-transform:uppercase;
      color:var(--mist); margin-bottom:6px;
    }
    .now-item-value {
      font-family:'Cormorant Garamond',serif;
      font-style:italic; font-size:18px; color:var(--ink); font-weight:400;
    }

    /* ── Section frame ── */
    .gl-section { padding:72px 64px 8px; }
    .gl-section-head {
      display:grid; grid-template-columns:1fr auto;
      align-items:baseline; margin-bottom:32px; gap:24px;
    }
    .gl-section-tag {
      font-size:10px; letter-spacing:0.3em; text-transform:uppercase;
      color:var(--mist); margin-bottom:12px;
      display:flex; align-items:center; gap:14px;
    }
    .gl-section-tag-accent { width:18px; height:2px; background:var(--fog-grad); }
    .gl-section-title {
      font-family:'Cormorant Garamond',serif;
      font-size:46px; font-weight:300;
      letter-spacing:-0.012em; color:var(--ink); line-height:1.05;
    }
    .gl-section-link {
      font-size:10px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--seaD); cursor:pointer; text-decoration:none;
      border-bottom:0.5px solid var(--fog); padding-bottom:2px;
    }

    /* ── Divider ── */
    .gl-divider {
      display:flex; align-items:center; gap:20px;
      padding:56px 64px 0;
    }
    .gl-divider-line { flex:1; height:0.5px; background:var(--ruleS); }
    .gl-divider-text {
      font-size:9.5px; letter-spacing:0.3em; text-transform:uppercase;
      color:var(--mist);
    }

    /* ── Reports ── */
    .reports-main { display:grid; grid-template-columns:1.4fr 1fr; gap:6px; }
    .report-featured {
      background:var(--night); padding:40px 36px; min-height:260px;
      display:flex; flex-direction:column; justify-content:space-between;
      color:var(--paper); position:relative; overflow:hidden;
      text-decoration:none;
    }
    .report-featured:hover { background:#354757; }
    .report-featured .fog-line { position:absolute; top:0; left:0; right:0; height:2px; width:100%; }
    .report-tag { font-size:9.5px; letter-spacing:0.24em; text-transform:uppercase; color:var(--sky); }
    .report-title {
      font-family:'Cormorant Garamond',serif;
      font-size:30px; color:var(--paper); font-weight:300; line-height:1.2; margin-bottom:14px;
    }
    .report-sub {
      font-family:'Cormorant Garamond',serif; font-style:italic;
      font-size:14px; color:rgba(236,230,214,0.78); line-height:1.7; max-width:520px;
    }
    .report-foot {
      display:flex; justify-content:space-between; align-items:center; margin-top:20px;
    }
    .report-foot-label {
      font-size:10px; letter-spacing:0.22em; text-transform:uppercase;
      color:rgba(255,255,255,0.45);
    }
    .report-arrow { color:var(--sky); font-size:18px; }
    .report-paper {
      background:var(--paper2); padding:30px; min-height:260px;
      display:flex; flex-direction:column; justify-content:space-between;
      border:0.5px solid var(--ruleS); text-decoration:none;
      position:relative;
    }
    .report-paper:hover { background:var(--paperD); }
    .report-paper-accent {
      position:absolute; top:0; left:0; bottom:0; width:2px; background:var(--linen);
    }
    .report-paper .report-tag { color:var(--seaD); }
    .report-paper .report-title {
      font-size:22px; color:var(--ink); margin-bottom:10px;
    }
    .report-paper .report-sub { font-size:13px; color:var(--ink2); }
    .report-paper-arrow { color:var(--seaD); font-size:14px; align-self:flex-end; }
    .reports-strip {
      display:grid; grid-template-columns:1fr 1fr 1fr;
      gap:1px; background:var(--ruleS); margin-top:1px;
    }
    .report-strip-card { background:var(--paperD); padding:22px; min-height:104px; }
    .report-strip-tag {
      font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--mist); margin-bottom:10px;
    }
    .report-strip-title {
      font-family:'Cormorant Garamond',serif;
      font-size:17px; color:var(--ink); font-weight:400; line-height:1.4;
    }

    /* ── Gallery ── */
    .gk { position:relative; overflow:hidden; background:var(--sky2); }
    .gk img {
      position:absolute; inset:0; width:100%; height:100%;
      object-fit:cover; transition:transform .6s ease; display:block;
    }
    .gk:hover img { transform:scale(1.04); }
    .gk-fallback { position:absolute; inset:0; width:100%; height:100%; }
    .gk-caption {
      position:absolute; left:14px; bottom:12px;
      font-family:'Cormorant Garamond',serif; font-style:italic;
      font-size:13px; color:rgba(236,230,214,0.9);
      text-shadow:0 1px 4px rgba(0,0,0,0.4);
      pointer-events:none;
    }
    .gk-overlay {
      position:absolute; inset:0;
      background:linear-gradient(180deg,transparent 55%,rgba(42,53,64,0.45) 100%);
      pointer-events:none;
    }
    .gallery-row1 { display:grid; grid-template-columns:1.6fr 1fr; gap:6px; height:420px; }
    .gallery-row1-right { display:grid; grid-template-rows:1fr 1fr; gap:6px; }
    .gallery-row2 { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-top:6px; height:200px; }
    .gallery-row3 { display:grid; grid-template-columns:1fr 1.4fr 1fr; gap:6px; margin-top:6px; height:220px; }

    /* ── Writing ── */
    .writing-list { border-top:0.5px solid var(--ruleS); }
    .writing-row {
      display:grid; grid-template-columns:140px 1fr 130px;
      gap:32px; padding:22px 0;
      border-bottom:0.5px solid var(--ruleS);
      align-items:baseline;
    }
    .writing-date {
      font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--mist);
    }
    .writing-topic {
      font-family:'Cormorant Garamond',serif; font-style:italic;
      font-size:13px; color:var(--ink2); margin-top:4px;
    }
    .writing-title {
      font-family:'Cormorant Garamond',serif;
      font-size:21px; color:var(--ink); font-weight:400;
      line-height:1.35; margin-bottom:6px;
    }
    .writing-excerpt { font-size:13px; color:var(--ink2); line-height:1.75; max-width:640px; }
    .writing-source {
      text-align:right; display:flex; align-items:center;
      gap:8px; justify-content:flex-end;
    }
    .writing-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
    .dot-sub { background:var(--seaD); }
    .dot-med { background:var(--linen); }
    .writing-link {
      font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
      color:var(--ink); text-decoration:none; transition:color .2s;
    }
    .writing-link:hover { color:var(--seaD); }

    /* ── Reading ── */
    .reading-grid { display:grid; grid-template-columns:1fr 1fr; gap:0 48px; }
    .reading-row {
      display:grid; grid-template-columns:10px 1fr auto;
      gap:16px; align-items:baseline; padding:16px 0;
      border-bottom:0.5px solid var(--ruleS);
    }
    .reading-dot {
      width:8px; height:8px; border-radius:50%;
      align-self:center; flex-shrink:0;
    }
    .reading-title {
      font-family:'Cormorant Garamond',serif;
      font-size:18px; color:var(--ink); font-weight:400; line-height:1.3;
    }
    .reading-author { font-size:12px; color:var(--ink2); margin-top:3px; }
    .reading-note { color:var(--mist); }
    .reading-status {
      font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--mist);
    }

    /* ── Hikes ── */
    .hikes-wrap {
      background:var(--paper2); border:0.5px solid var(--ruleS);
      padding:30px 32px;
    }
    .hikes-header {
      display:flex; align-items:baseline; justify-content:space-between;
      margin-bottom:18px;
    }
    .hikes-subtitle {
      font-family:'Cormorant Garamond',serif; font-style:italic;
      font-size:18px; color:var(--ink2);
    }
    .hikes-totals {
      font-size:10px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--mist);
    }
    .hikes-grid {
      display:grid; grid-template-columns:repeat(5,1fr); gap:10px;
      margin-top:22px;
    }
    .hike-card { border-top:0.5px solid var(--ruleS); padding-top:10px; }
    .hike-meta {
      display:flex; align-items:baseline; gap:6px; margin-bottom:4px;
    }
    .hike-country {
      font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--seaD); font-weight:500;
    }
    .hike-date {
      font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--mist);
    }
    .hike-name {
      font-family:'Cormorant Garamond',serif;
      font-size:15px; color:var(--ink); font-weight:400; line-height:1.25; margin-bottom:6px;
    }
    .hike-stats { font-size:11px; color:var(--ink2); font-variant-numeric:tabular-nums; }
    .hike-note {
      font-family:'Cormorant Garamond',serif; font-style:italic;
      font-size:12px; color:var(--mist); margin-top:6px; line-height:1.5;
    }

    /* ── Side projects ── */
    .side-grid {
      display:grid; grid-template-columns:repeat(4,1fr);
      gap:1px; background:var(--ruleS);
    }
    .side-card {
      background:var(--paper2); padding:22px; min-height:160px;
      display:flex; flex-direction:column; justify-content:space-between;
      cursor:pointer; position:relative; overflow:hidden;
    }
    .side-card:hover { background:var(--paperD); }
    .side-accent { position:absolute; top:0; left:0; right:0; height:2px; }
    .side-kind {
      font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase;
      margin-top:8px;
    }
    .side-title {
      font-family:'Cormorant Garamond',serif;
      font-size:20px; color:var(--ink); font-weight:400;
      line-height:1.25; margin-bottom:8px;
    }
    .side-sub { font-size:12px; color:var(--ink2); line-height:1.65; }

    /* ── Contact ── */
    .contact-wrap {
      margin-top:72px; padding:80px 64px 60px;
      background:var(--night); color:var(--paper);
      position:relative; overflow:hidden;
    }
    .contact-glow {
      position:absolute; inset:auto -240px -240px 30%;
      width:900px; height:500px;
      background:radial-gradient(ellipse, rgba(185,200,212,0.18), transparent 60%);
      pointer-events:none;
    }
    .contact-grid {
      position:relative;
      display:grid; grid-template-columns:1.2fr 1fr; gap:60px;
    }
    .contact-eyebrow {
      font-size:10px; letter-spacing:0.34em; text-transform:uppercase;
      color:var(--sky); margin-bottom:14px;
    }
    .contact-title {
      font-family:'Cormorant Garamond',serif;
      font-size:64px; font-weight:300;
      letter-spacing:-0.012em; line-height:1.0;
    }
    .contact-sub {
      margin-top:18px;
      font-family:'Cormorant Garamond',serif; font-style:italic;
      font-size:19px; color:rgba(236,230,214,0.78);
      max-width:460px; line-height:1.6;
    }
    .contact-details { margin-top:36px; display:flex; flex-direction:column; gap:14px; }
    .contact-label {
      font-size:10px; letter-spacing:0.26em; text-transform:uppercase;
      color:var(--mist);
    }
    .contact-val { font-size:15px; color:var(--paper); text-decoration:none; display:block; }
    .contact-val:hover { color:var(--sky); }
    .contact-socials { display:flex; gap:18px; margin-top:28px; flex-wrap:wrap; }
    .contact-social {
      font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
      color:rgba(236,230,214,0.82); text-decoration:none;
      border-bottom:0.5px solid var(--edge2); padding-bottom:2px;
      transition:color .2s, border-color .2s;
    }
    .contact-social:hover { color:var(--paper); border-color:var(--edge2); }
    .contact-form { display:flex; flex-direction:column; gap:20px; }
    .cf-group { display:flex; flex-direction:column; gap:5px; }
    .cf-label {
      font-size:9.5px; letter-spacing:0.26em; text-transform:uppercase;
      color:var(--mist);
    }
    .cf-input {
      background:transparent; border:none;
      border-bottom:0.5px solid var(--edge2);
      padding:8px 0; font-family:'Instrument Sans',sans-serif;
      font-size:14px; color:var(--paper); font-weight:300;
      outline:none; transition:border-color .2s; width:100%;
    }
    .cf-input::placeholder { color:rgba(236,230,214,0.28); font-style:italic; }
    .cf-input:focus { border-color:var(--sky); }
    textarea.cf-input { resize:none; height:80px; }
    .cf-row { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
    .btn-send {
      align-self:flex-start;
      background:transparent; border:0.5px solid var(--sky);
      color:var(--sky); padding:12px 26px;
      font-family:'Instrument Sans',sans-serif;
      font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase;
      cursor:pointer; font-weight:400;
      transition:all .2s; margin-top:6px;
    }
    .btn-send:hover { background:var(--seaD); border-color:var(--seaD); color:var(--paper); }

    /* ── Footer ── */
    footer {
      background:var(--nightD); padding:20px 64px;
      display:flex; justify-content:space-between; align-items:center;
    }
    .fc { font-size:10px; color:#7a8896; letter-spacing:0.08em; }
    .fr {
      font-family:'Cormorant Garamond',serif;
      font-style:italic; font-size:13px; color:#7a8896;
    }

    /* ── Places ── */
    .places-strip {
      display:grid; grid-template-columns:repeat(5,1fr); gap:1px;
      background:var(--ruleS);
    }
    .place-card {
      background:var(--paper2); padding:20px 18px;
      display:flex; flex-direction:column; gap:6px;
    }
    .place-code {
      font-size:9px; letter-spacing:0.32em; text-transform:uppercase;
      color:var(--seaD);
    }
    .place-name {
      font-family:'Cormorant Garamond',serif;
      font-size:18px; color:var(--ink); font-weight:400; line-height:1.2;
    }
    .place-note {
      font-family:'Cormorant Garamond',serif; font-style:italic;
      font-size:12px; color:var(--mist); line-height:1.4;
    }

    /* ── Accounts of Life ── */
    .book-callout {
      display:grid; grid-template-columns:1fr 1.8fr; gap:0;
      margin-top:0; border:0.5px solid var(--ruleS);
    }
    .book-spine {
      background:var(--night); padding:36px 28px;
      display:flex; flex-direction:column; justify-content:space-between;
      position:relative; overflow:hidden;
    }
    .book-spine-fog { position:absolute; top:0; left:0; right:0; height:2px; }
    .book-kind {
      font-size:9px; letter-spacing:0.32em; text-transform:uppercase;
      color:var(--sky);
    }
    .book-title {
      font-family:'Cormorant Garamond',serif;
      font-size:36px; font-weight:300; line-height:1.05;
      color:var(--paper); letter-spacing:-0.01em;
    }
    .book-title em { font-style:italic; }
    .book-author-tag {
      font-size:10px; letter-spacing:0.22em; text-transform:uppercase;
      color:rgba(236,230,214,0.55);
    }
    .book-body {
      background:var(--paper2); padding:36px 40px;
      display:flex; flex-direction:column; justify-content:space-between;
      border-left:0.5px solid var(--ruleS);
    }
    .book-desc {
      font-family:'Cormorant Garamond',serif; font-style:italic;
      font-size:17px; color:var(--ink2); line-height:1.7; max-width:520px;
    }
    .book-link {
      display:inline-block; margin-top:28px;
      font-size:10px; letter-spacing:0.22em; text-transform:uppercase;
      color:var(--seaD); text-decoration:none;
      border-bottom:0.5px solid var(--fog); padding-bottom:2px;
    }
    .book-link:hover { color:var(--ink); border-color:var(--ink); }

    /* ── Fade-up animation ── */
    .fade-up { opacity:0; transform:translateY(14px); transition:opacity .6s ease, transform .6s ease; }
    .fade-up.visible { opacity:1; transform:none; }

    /* ── Responsive ── */
    @media (max-width:960px) {
      nav { padding:16px 24px; grid-template-columns:1fr auto; }
      .nav-status { display:none; }
      .nav-links { gap:18px; font-size:9.5px; }
      .hero { grid-template-columns:1fr; min-height:auto; }
      .hero-left { padding:48px 24px; border-right:none; border-bottom:0.5px solid var(--ruleS); }
      .hero-right { min-height:320px; }
      .now-strip { padding:32px 24px; grid-template-columns:1fr; gap:24px; }
      .now-grid { grid-template-columns:repeat(2,1fr); gap:16px 32px; }
      .gl-section { padding:48px 24px 8px; }
      .gl-divider { padding:40px 24px 0; }
      .reports-main { grid-template-columns:1fr; }
      .gallery-row1{grid-template-columns:1fr;height:auto}
      .gallery-row1 .gk{height:240px}
