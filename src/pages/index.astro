      .places-strip{grid-template-columns:repeat(2,1fr)}
      .book-callout{grid-template-columns:1fr}
      .writing-row { grid-template-columns:1fr; gap:8px; }
      .writing-date { display:none; }
      .writing-source { justify-content:flex-start; }
      .reading-grid { grid-template-columns:1fr; }
