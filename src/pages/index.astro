---
// Photo setup:
// Put photos in /public/ with these exact names:
// hero-1.jpg, hero-2.jpg, hero-3.jpg
// gallery-1.jpg ... gallery-6.jpg
// Missing photos show colour placeholders automatically.
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ambuj Tripathi — Finance, Credit Risk &amp; Photography</title>
  <meta name="description" content="Finance professional writing at the intersection of credit risk, development finance, and global markets. Based in Utrecht, Netherlands." />
  <meta property="og:title" content="Ambuj Tripathi" />
  <meta property="og:description" content="Finance · Credit Risk · Development Finance · Photography" />
  <meta property="og:url" content="https://ambujtripathi.nl" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Instrument+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root{--ink:#1e2d35;--ink2:#3d5260;--mist:#7d9aaa;--fog:#c2d3db;--ice:#dce9ee;--snow:#eff5f8;--paper:#f7fafb;--linen:#f0ede8;--warm:#e8e2d9;--blue:#3a7296;--blue2:#cfe0ea;--sand:#c4b89a}
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{font-family:'Instrument Sans',sans-serif;background:var(--paper);color:var(--ink);font-weight:300;line-height:1.7;overflow-x:hidden}
    nav{display:flex;justify-content:space-between;align-items:center;padding:20px 56px;border-bottom:0.5px solid var(--fog);position:sticky;top:0;background:rgba(247,250,251,0.95);backdrop-filter:blur(12px);z-index:200}
    .nav-logo{font-family:'Cormorant Garamond',serif;font-size:18px;letter-spacing:0.06em;color:var(--ink);font-weight:400}
    .nav-links{display:flex;gap:36px;list-style:none}
    .nav-links a{font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink2);text-decoration:none;font-weight:400;transition:color .2s;cursor:pointer}
    .nav-links a:hover{color:var(--blue)}
    .hero{display:grid;grid-template-columns:55fr 45fr;min-height:92vh}
    .hero-left{padding:72px 56px;display:flex;flex-direction:column;justify-content:space-between;border-right:0.5px solid var(--fog)}
    .hero-eyebrow{font-size:10px;letter-spacing:0.26em;text-transform:uppercase;color:var(--mist);font-weight:400}
    .hero-name{font-family:'Cormorant Garamond',serif;font-size:72px;font-weight:300;line-height:1.0;color:var(--ink);letter-spacing:-0.01em;margin-top:20px}
    .hero-name em{font-style:italic;color:var(--blue);font-weight:300}
    .hero-rule{width:48px;height:0.5px;background:var(--fog);margin:28px 0}
    .hero-role{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:20px;color:var(--mist);font-weight:300;line-height:1.5}
    .hero-bio{font-size:14px;color:var(--ink2);max-width:420px;line-height:1.9;font-weight:300}
    .hero-bio strong{font-weight:500;color:var(--ink)}
    .hero-bottom{display:flex;flex-direction:column;gap:24px}
    .hero-actions{display:flex;gap:14px;align-items:center}
    .btn-primary{background:var(--ink);color:var(--snow);padding:11px 26px;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;border:none;cursor:pointer;font-family:'Instrument Sans',sans-serif;font-weight:400;transition:background .2s}
    .btn-primary:hover{background:var(--blue)}
    .btn-ghost{color:var(--ink2);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;font-weight:400;border:none;border-bottom:0.5px solid var(--fog);padding-bottom:1px;background:none;cursor:pointer;font-family:'Instrument Sans',sans-serif;transition:color .2s,border-color .2s}
    .btn-ghost:hover{color:var(--blue);border-color:var(--blue)}
    .hero-socials{display:flex;gap:22px;flex-wrap:wrap}
    .social-link{font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:var(--mist);text-decoration:none;transition:color .2s}
    .social-link:hover{color:var(--blue)}
    .hero-right{display:grid;grid-template-rows:1fr 1fr;background:var(--linen)}
    .hero-photo-top{position:relative;overflow:hidden;cursor:pointer}
    .hero-photo-top:hover img,.hero-photo-top:hover .ph-fb{transform:scale(1.04)}
    .hero-photo-top img,.ph-fb{width:100%;height:100%;min-height:240px;object-fit:cover;transition:transform .7s ease;display:block}
    .ph-caption{position:absolute;bottom:16px;left:20px;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:13px;color:rgba(255,255,255,0.55);font-weight:300}
    .hero-photo-bottom{display:grid;grid-template-columns:1fr 1fr;border-top:0.5px solid rgba(255,255,255,0.12)}
    .hero-photo-sm{overflow:hidden;cursor:pointer;position:relative}
    .hero-photo-sm:first-child{border-right:0.5px solid rgba(255,255,255,0.12)}
    .hero-photo-sm:hover img,.hero-photo-sm:hover .ph-fb{transform:scale(1.05)}
    .hero-photo-sm img{width:100%;height:100%;min-height:180px;object-fit:cover;display:block;transition:transform .7s ease}
    .ph-f1{background:linear-gradient(160deg,#4a7fa8,#2d5f82)}
    .ph-f2{background:linear-gradient(145deg,#6a8e7a,#4a7060)}
    .ph-f3{background:linear-gradient(140deg,#8ab0c4,#5a8090)}
    .divider{display:flex;align-items:center;gap:20px;padding:0 56px;margin:56px 0 48px}
    .divider-line{flex:1;height:0.5px;background:var(--fog)}
    .divider-text{font-size:9px;letter-spacing:0.26em;text-transform:uppercase;color:var(--mist);white-space:nowrap}
    .section{padding:0 56px 80px}
    .section-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:40px}
    .section-title{font-family:'Cormorant Garamond',serif;font-size:38px;font-weight:300;color:var(--ink);letter-spacing:-0.01em}
    .section-link{font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:var(--blue);text-decoration:none}
    .gallery-kinfolk{display:grid;grid-template-columns:1.6fr 1fr;gap:3px}
    .gallery-side{display:grid;grid-template-rows:1fr 1fr;gap:3px}
    .gk{position:relative;overflow:hidden;cursor:pointer;background:var(--ice)}
    .gk img,.g-fill{width:100%;height:100%;min-height:180px;object-fit:cover;transition:transform .55s ease;display:block}
    .gk.tall img,.gk.tall .g-fill{min-height:380px}
    .gk:hover img,.gk:hover .g-fill{transform:scale(1.05)}
    .ga{background:linear-gradient(155deg,#3d7499,#2a5878)}
    .gb{background:linear-gradient(140deg,#5a8e78,#3d6a5a)}
    .gc{background:linear-gradient(150deg,#8ab0c4,#6090a8)}
    .gd{background:linear-gradient(135deg,#9ec5d8,#78afc5)}
    .ge{background:linear-gradient(160deg,#6a7e70,#4a6055)}
    .gallery-overlay{position:absolute;inset:0;background:rgba(20,32,38,0);display:flex;flex-direction:column;justify-content:flex-end;padding:18px;transition:background .3s}
    .gk:hover .gallery-overlay{background:rgba(20,32,38,0.52)}
    .g-tag{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0);transition:color .3s}
    .g-cap{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:15px;color:rgba(255,255,255,0);transition:color .3s;font-weight:300}
    .gk:hover .g-tag,.gk:hover .g-cap{color:rgba(255,255,255,0.92)}
    .reports-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px;margin-top:3px}
    .report-card{background:var(--ink);padding:38px;display:flex;flex-direction:column;justify-content:space-between;min-height:220px;cursor:pointer;transition:background .2s;position:relative;overflow:hidden}
    .report-card:hover{background:#263d4a}
    .report-card.featured{background:#2d607e}
    .report-card.featured:hover{background:#265270}
    .r-accent{position:absolute;top:0;left:0;right:0;height:2px}
    .r-blue{background:linear-gradient(90deg,#3a7296,transparent)}
    .r-sage{background:linear-gradient(90deg,#7a9e8e,transparent)}
    .r-tag{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--mist);font-weight:400;margin-bottom:14px}
    .r-title{font-family:'Cormorant Garamond',serif;font-size:21px;color:var(--snow);font-weight:300;line-height:1.4;flex:1}
    .r-sub{font-size:12px;color:var(--mist);margin-top:10px;line-height:1.6;font-style:italic}
    .r-arrow{align-self:flex-end;font-size:16px;color:var(--blue2);margin-top:20px;opacity:0.7}
    .finance-strip{display:grid;grid-template-columns:1fr 1fr 1fr;gap:3px;margin-top:3px}
    .fs-card{background:var(--linen);border:0.5px solid var(--warm);padding:28px;cursor:pointer;transition:background .2s,border-color .2s}
    .fs-card:hover{background:var(--warm);border-color:var(--sand)}
    .fs-tag{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--sand);margin-bottom:10px}
    .fs-title{font-family:'Cormorant Garamond',serif;font-size:17px;color:var(--ink);font-weight:400;line-height:1.45}
    .writing-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--fog)}
    .writing-card{background:var(--paper);padding:36px;cursor:pointer;transition:background .2s}
    .writing-card:hover{background:var(--snow)}
    .wp{display:inline-flex;align-items:center;gap:8px;font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--mist);margin-bottom:14px}
    .pdot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
    .d-sub{background:#e8601a}
    .d-med{background:#2a9d4e}
    .wc-title{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:400;line-height:1.35;color:var(--ink);margin-bottom:10px}
    .wc-excerpt{font-size:13px;color:var(--ink2);line-height:1.8;margin-bottom:18px;font-weight:300}
    .wc-foot{display:flex;justify-content:space-between;align-items:center}
    .wc-meta{font-size:11px;color:var(--mist);font-style:italic;font-family:'Cormorant Garamond',serif}
    .wc-read{font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--blue);text-decoration:none;transition:color .2s}
    .wc-read:hover{color:var(--ink)}
    .contact-wrap{background:var(--ink);padding:80px 56px;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
    .ct-title{font-family:'Cormorant Garamond',serif;font-size:42px;font-weight:300;color:var(--snow);margin-bottom:10px;letter-spacing:-0.01em}
    .ct-sub{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:17px;color:var(--mist);line-height:1.8;max-width:320px;font-weight:300}
    .ct-details{margin-top:36px;display:flex;flex-direction:column;gap:18px}
    .ct-label{font-size:9px;letter-spacing:0.22em;text-transform:uppercase;color:var(--mist);margin-bottom:2px}
    .ct-val{font-size:14px;color:var(--fog);text-decoration:none;transition:color .2s;display:block;font-weight:300}
    .ct-val:hover{color:var(--blue2)}
    .ct-socials{display:flex;gap:20px;margin-top:32px;flex-wrap:wrap}
    .ct-social{font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--mist);text-decoration:none;border-bottom:0.5px solid #253540;padding-bottom:2px;transition:color .2s,border-color .2s}
    .ct-social:hover{color:var(--fog);border-color:var(--mist)}
    .contact-form{display:flex;flex-direction:column;gap:20px}
    .fg{display:flex;flex-direction:column;gap:5px}
    .fl{font-size:9px;letter-spacing:0.22em;text-transform:uppercase;color:var(--mist)}
    .fi{background:transparent;border:none;border-bottom:0.5px solid #253540;padding:9px 0;font-family:'Instrument Sans',sans-serif;font-size:14px;color:var(--snow);font-weight:300;outline:none;transition:border-color .2s;width:100%}
    .fi::placeholder{color:#253540}
    .fi:focus{border-color:var(--blue)}
    textarea.fi{resize:none;height:88px}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:20px}
    .btn-send{align-self:flex-start;background:transparent;border:0.5px solid #3a5060;color:var(--fog);padding:12px 30px;font-family:'Instrument Sans',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;cursor:pointer;font-weight:400;transition:all .2s;margin-top:6px}
    .btn-send:hover{background:var(--blue);border-color:var(--blue);color:var(--snow)}
    footer{background:#0f1c23;padding:20px 56px;display:flex;justify-content:space-between;align-items:center}
    .fc{font-size:10px;color:#253540;letter-spacing:0.06em}
    .fr{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:13px;color:#253540}
    .lightbox{position:fixed;inset:0;background:rgba(10,20,26,0.94);z-index:1000;display:none;align-items:center;justify-content:center;cursor:pointer}
    .lightbox.open{display:flex}
    .lb-inner{width:560px;background:var(--ink);position:relative;cursor:default}
    .lb-img{height:380px;overflow:hidden}
    .lb-img img,.lb-fill{width:100%;height:100%;object-fit:cover;display:block}
    .lb-caption{padding:18px 22px}
    .lb-tag{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--mist);margin-bottom:4px}
    .lb-title{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:18px;color:var(--snow);font-weight:300}
    .lb-close{position:absolute;top:12px;right:14px;background:none;border:none;color:var(--mist);font-size:18px;cursor:pointer;transition:color .2s}
    .lb-close:hover{color:var(--snow)}
    .fade-up{opacity:0;transform:translateY(16px);transition:opacity .65s ease,transform .65s ease}
    .fade-up.visible{opacity:1;transform:none}
    @media(max-width:900px){
      nav{padding:16px 24px}
      .nav-links{gap:20px}
      .hero{grid-template-columns:1fr;min-height:auto}
      .hero-left{padding:48px 24px}
      .hero-right{display:none}
      .hero-name{font-size:52px}
      .section,.divider{padding-left:24px;padding-right:24px}
      .reports-grid,.writing-grid,.finance-strip{grid-template-columns:1fr}
      .gallery-kinfolk{grid-template-columns:1fr}
      .gallery-side{grid-template-columns:1fr 1fr;grid-template-rows:auto}
      .contact-wrap{grid-template-columns:1fr;padding:60px 24px;gap:48px}
      footer{padding:16px 24px;flex-direction:column;gap:6px;text-align:center}
    }
  </style>
</head>
<body>

<nav>
  <span class="nav-logo">Ambuj Tripathi</span>
  <ul class="nav-links">
    <li><a onclick="document.getElementById('work').scrollIntoView({behavior:'smooth'})">Work</a></li>
    <li><a onclick="document.getElementById('writing').scrollIntoView({behavior:'smooth'})">Writing</a></li>
    <li><a onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})">Contact</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-left fade-up">
    <div>
      <p class="hero-eyebrow">Utrecht · India · The world</p>
      <div style="height:20px"></div>
      <h1 class="hero-name">Ambuj<br /><em>Tripathi</em></h1>
      <div class="hero-rule"></div>
      <p class="hero-role">Finance · Credit Risk<br />Development Finance · Photography</p>
    </div>
    <p class="hero-bio">Finance professional writing and thinking at the intersection of <strong>credit risk</strong>, <strong>development finance</strong>, and global markets. Occasional photographer. Always curious about what numbers leave out.</p>
    <div class="hero-bottom">
      <div class="hero-actions">
        <button class="btn-primary" onclick="document.getElementById('work').scrollIntoView({behavior:'smooth'})">View work</button>
        <button class="btn-ghost" onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})">Get in touch</button>
      </div>
      <div class="hero-socials">
        <a class="social-link" href="https://www.linkedin.com/in/ambuj1tripathi/" target="_blank" rel="noopener">LinkedIn</a>
        <a class="social-link" href="https://github.com/ambuj1tripathi-debug" target="_blank" rel="noopener">GitHub</a>
        <a class="social-link" href="https://medium.com/@ambuj1tripathi" target="_blank" rel="noopener">Medium</a>
        <a class="social-link" href="https://dtrt.substack.com/" target="_blank" rel="noopener">Substack</a>
      </div>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-photo-top" onclick="openLightbox('Utrecht, early light','Photography · Netherlands','ph1')">
      <img src="/hero-1.jpg" alt="Utrecht, early light" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
      <div class="ph-fb ph-f1" style="display:none;min-height:240px"></div>
      <span class="ph-caption">Utrecht, early light</span>
    </div>
    <div class="hero-photo-bottom">
      <div class="hero-photo-sm" onclick="openLightbox('Delhi rooftops','Photography · India','ph2')">
        <img src="/hero-2.jpg" alt="Delhi rooftops" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
        <div class="ph-fb ph-f2" style="display:none;min-height:180px"></div>
      </div>
      <div class="hero-photo-sm" onclick="openLightbox('Somewhere in between','Travel','ph3')">
        <img src="/hero-3.jpg" alt="Travel" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
        <div class="ph-fb ph-f3" style="display:none;min-height:180px"></div>
      </div>
    </div>
  </div>
</section>

<div class="divider fade-up">
  <div class="divider-line"></div>
  <span class="divider-text">Work &amp; projects</span>
  <div class="divider-line"></div>
</div>

<section class="section fade-up" id="work">
  <div class="section-header">
    <h2 class="section-title">Photography</h2>
  </div>
  <div class="gallery-kinfolk">
    <div class="gk tall" onclick="openLightbox('Utrecht, Oudegracht','Photography · Netherlands','ga')">
      <img src="/gallery-1.jpg" alt="Oudegracht, late afternoon" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
      <div class="g-fill ga" style="display:none"></div>
      <div class="gallery-overlay"><span class="g-tag">Featured · Utrecht</span><span class="g-cap">Oudegracht, late afternoon</span></div>
    </div>
    <div class="gallery-side">
      <div class="gk" onclick="openLightbox('Canal light, winter','Photography · Netherlands','gb')">
        <img src="/gallery-2.jpg" alt="Canal light, winter" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
        <div class="g-fill gb" style="display:none"></div>
        <div class="gallery-overlay"><span class="g-tag">Utrecht</span><span class="g-cap">Canal light, winter</span></div>
      </div>
      <div class="gk" onclick="openLightbox('Dom tower, dusk','Photography · Netherlands','gc')">
        <img src="/gallery-3.jpg" alt="Dom tower, dusk" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
        <div class="g-fill gc" style="display:none"></div>
        <div class="gallery-overlay"><span class="g-tag">Utrecht</span><span class="g-cap">Dom tower, dusk</span></div>
      </div>
    </div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:3px;margin-top:3px">
    <div class="gk" onclick="openLightbox('Bridges and bicycles','Photography · Utrecht','gb')">
      <img src="/gallery-4.jpg" alt="Bridges and bicycles" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
      <div class="g-fill gb" style="display:none;min-height:200px"></div>
      <div class="gallery-overlay"><span class="g-tag">Utrecht</span><span class="g-cap">Bridges and bicycles</span></div>
    </div>
    <div class="gk" onclick="openLightbox('Morning on the Singel','Photography · Netherlands','ga')">
      <img src="/gallery-5.jpg" alt="Morning on the Singel" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
      <div class="g-fill gd" style="display:none;min-height:200px"></div>
      <div class="gallery-overlay"><span class="g-tag">Utrecht</span><span class="g-cap">Morning on the Singel</span></div>
    </div>
    <div class="gk" onclick="openLightbox('Wharfcellars, golden hour','Photography · Utrecht','gc')">
      <img src="/gallery-6.jpg" alt="Wharfcellars, golden hour" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
      <div class="g-fill ge" style="display:none;min-height:200px"></div>
      <div class="gallery-overlay"><span class="g-tag">Utrecht</span><span class="g-cap">Wharfcellars, golden hour</span></div>
    </div>
  </div>

  <div class="section-header" style="margin-top:60px">
    <h2 class="section-title">Research &amp; Reports</h2>
  </div>
  <div class="reports-grid">
    <div class="report-card featured">
      <div class="r-accent r-blue"></div>
      <span class="r-tag">Finance · Energy · 2025</span>
      <p class="r-title">The Strait That Shook the World</p>
      <p class="r-sub">Iran, Hormuz, and the Uneven Road to Energy Transition — how the largest oil supply disruption in history is simultaneously accelerating the clean energy pivot and threatening the minerals the transition depends on.</p>
      <span class="r-arrow">→</span>
    </div>
    <div class="report-card">
      <div class="r-accent r-sage"></div>
      <span class="r-tag">Private Credit · 2025</span>
      <p class="r-title">Beyond the Banks: The Rise and Rule of Private Credit Markets</p>
      <p class="r-sub">From niche lending to a trillion-dollar force — how private credit rewrote the rules of corporate finance.</p>
      <span class="r-arrow">→</span>
    </div>
  </div>
  <div class="finance-strip">
    <div class="fs-card"><p class="fs-tag">Credit Risk · MBA</p><p class="fs-title">Credit Risk Modelling &amp; Portfolio Stress Testing</p></div>
    <div class="fs-card"><p class="fs-tag">Development Finance</p><p class="fs-title">Impact Investment Frameworks for Emerging Markets</p></div>
    <div class="fs-card"><p class="fs-tag">Corporate Governance</p><p class="fs-title">Cross-Shareholding and Corporate Governance in Japan</p></div>
  </div>
