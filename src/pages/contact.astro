  <p>
    Best reached by email. I respond within a day or two.
  </p>

  <ul class="contact-links">
    <li>
      <span class="label">Email</span>
      <a href="mailto:ambuj@ambujtripathi.nl">ambuj@ambujtripathi.nl</a>
    </li>
    <li>
      <span class="label">LinkedIn</span>
      <a href="https://linkedin.com/in/PLACEHOLDER" target="_blank" rel="noopener">linkedin.com/in/PLACEHOLDER</a>
    </li>
    <li>
      <span class="label">Substack</span>
      <a href="https://substack.com/@PLACEHOLDER" target="_blank" rel="noopener">substack.com/@PLACEHOLDER</a>
    </li>
    <li>
      <span class="label">Medium</span>
      <a href="https://medium.com/@PLACEHOLDER" target="_blank" rel="noopener">medium.com/@PLACEHOLDER</a>
    </li>
  </ul>

  <hr />

  <p style="font-family: var(--font-sans); font-size: 0.88rem; color: var(--mid-grey);">
