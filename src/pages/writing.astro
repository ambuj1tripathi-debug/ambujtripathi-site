<Base title="Writing" description="Articles by Ambuj Tripathi on energy transition, sovereign credit, and infrastructure finance.">
  <h1 class="page-title">Writing</h1>
  <p class="page-subtitle">
    Essays on energy transition, sovereign credit, and the economics of infrastructure.
    Published on <a href="https://substack.com/@PLACEHOLDER" target="_blank" rel="noopener">Substack</a>
    and <a href="https://medium.com/@PLACEHOLDER" target="_blank" rel="noopener">Medium</a>.
  </p>

  <ul class="article-list">
    {articles.map(article => (
      <li class="article-card">
        <div class="meta">{article.publication} · {article.date}</div>
        <h3><a href={article.url} target="_blank" rel="noopener">{article.title}</a></h3>
        <p class="description">{article.description}</p>
      </li>
    ))}
  </ul>
</Base>
